# ==============================================================================
# Environment Configuration Template
# Copy this file to '.env' and fill in your actual credentials.
# NEVER commit the '.env' file to Git!
# ==============================================================================

# Pipeline Environment: dev, staging, or prod
ENV=dev

# Local Paths
PROJECT_ROOT=/Users/shashi/Projects/Personal/Loan_Risk_Pipeline
RAW_DATA_PATH=${PROJECT_ROOT}/data/raw
PROCESSED_DATA_PATH=${PROJECT_ROOT}/data/processed

# Google Cloud Platform (GCP) Configuration
# (We will configure these in Phase 7)
GCP_PROJECT_ID=your-gcp-project-id
GCP_DATASET_NAME=loan_risk_dw
GOOGLE_APPLICATION_CREDENTIALS=${PROJECT_ROOT}/config/gcp-credentials.json
